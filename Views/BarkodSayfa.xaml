<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="Saller_System.Views.BarkodSayfa"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <Grid RowDefinitions="Auto,*">

        <!-- Üst kısım — kamera -->
        <Grid Grid.Row="0" HeightRequest="280">
            <zxing:CameraBarcodeReaderView
        x:Name="BarkodOkuyucu"
        IsDetecting="False"
        BarcodesDetected="BarkodOkundu"/>
            <Label Text="📷 Barkodu kameraya tutun"
           HorizontalOptions="Center"
           VerticalOptions="End"
           Margin="0,0,0,10"
           TextColor="White"
           FontSize="13"
           BackgroundColor="#80000000"
           Padding="8,4"/>
        </Grid>


        <!-- Alt kısım — kontroller -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

                <Button x:Name="KameraBtn"
                        Text="🔦 Kamerayı Aç"
                        Style="{StaticResource PrimaryBtn}"
                        Clicked="KameraToggleClicked"/>

                <Label Text="— veya barkod yazın —"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"/>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           x:Name="BarkodEntry"
                           Placeholder="Barkod numarası"
                           Keyboard="Numeric"/>
                    <Button Grid.Column="1"
                            Text="Getir"
                            Style="{StaticResource PrimaryBtn}"
                            WidthRequest="80"
                            Clicked="UrunGetirClicked"/>
                </Grid>

                <!-- Ürün bilgi kartı -->
                <VerticalStackLayout x:Name="UrunBilgiFrame"
                                     IsVisible="False"
                                     Spacing="8" Padding="16"
                                     BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}">
                    <Label x:Name="UrunAdLabel"
                           FontSize="18" FontAttributes="Bold"/>
                    <Label x:Name="UrunFiyatLabel"
                           FontSize="16"
                           TextColor="{StaticResource Success}"/>
                    <Label x:Name="UrunKategoriLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"/>
                    <Entry x:Name="AdetEntry"
                           Placeholder="Adet"
                           Keyboard="Numeric"
                           Text="1"/>
                    <Button Text="✅ Sepete Ekle"
                            Style="{StaticResource SuccessBtn}"
                            Clicked="SatisaEkleClicked"/>
                </VerticalStackLayout>

                <Label x:Name="MesajLabel"
                       TextColor="{StaticResource Success}"
                       HorizontalOptions="Center"
                       IsVisible="False"/>

                <Button Text="🛒 Sepete Git"
                        BackgroundColor="#7C3AED"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="52"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="SepeteGitClicked"/>

                <Button Text="⬅ Geri"
                        Style="{StaticResource GrayBtn}"
                        Clicked="GeriClicked"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>