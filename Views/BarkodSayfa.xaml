<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="Saller_System.Views.BarkodSayfa"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="260,Auto,*">
        <!-- Kamera yüksekliği 260, alt açıklama Auto, geri kalan ScrollView -->

        <!-- Kamera -->
        <zxing:CameraBarcodeReaderView
            x:Name="BarkodOkuyucu"
            Grid.Row="0"
            IsDetecting="False"
            BarcodesDetected="BarkodOkundu"/>

        <!-- Kamera altı açıklama -->
        <Border Grid.Row="1"
        BackgroundColor="#00000000"
        Stroke="Transparent"
          Padding="15,100,15,6">
            <Label Text="📷 Barkodu kameraya tutun"
           HorizontalOptions="Center"
           TextColor="White"
           FontSize="13"/>
        </Border>

        <!-- Alt kısım -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,120,20,32" Spacing="14">

                <!-- Barkod giriş ve Getir -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#1E293B}"
                            Padding="14,4"
                            HeightRequest="54">
                        <Entry x:Name="BarkodEntry"
                               Placeholder="Barkod numarası"
                               Keyboard="Numeric"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"
                               Completed="BarkodEntry_Completed"/>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 14"
                            Padding="18,0"
                            HeightRequest="54"
                            WidthRequest="80">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="UrunGetirTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="Getir"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="14"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Ürün bilgi kartı -->
                <Border x:Name="UrunBilgiFrame"
                        IsVisible="False"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="UrunAdLabel" FontSize="18" FontAttributes="Bold"/>
                        <Label x:Name="UrunFiyatLabel" FontSize="16" TextColor="{StaticResource Success}"/>
                        <Label x:Name="UrunKategoriLabel" FontSize="13"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"/>
                        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#0F172A}"
                                Padding="14,4"
                                HeightRequest="50">
                            <Entry x:Name="AdetEntry"
                                   Placeholder="Adet"
                                   Keyboard="Numeric"
                                   Text="1"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Border BackgroundColor="{StaticResource Success}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 14"
                                Padding="0,16"
                                HeightRequest="54">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="SatisaEkleTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="✅ Sepete Ekle"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Mesaj -->
                <Border x:Name="MesajBorder"
                        IsVisible="False"
                        BackgroundColor="{AppThemeBinding Light=#DCFCE7, Dark=#14532D}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 12"
                        Padding="14,10">
                    <Label x:Name="MesajLabel"
                           TextColor="{AppThemeBinding Light=#16A34A, Dark=#86EFAC}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <!-- Sepete Git -->
                <Border BackgroundColor="#7C3AED"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 16"
                        Padding="0,16"
                        HeightRequest="56">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SepeteGitClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="🛒 Sepete Git"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Geri -->
                <Border BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 16"
                        Padding="0,16"
                        HeightRequest="56">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GeriClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="⬅ Geri"
                           TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                           FontAttributes="Bold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>