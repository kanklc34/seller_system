<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Saller_System.Views.Raporlar"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20,18,20,20" RowSpacing="15">

        <Border Grid.Row="0" BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20,16">
            <HorizontalStackLayout Spacing="10">
                <Label Text="📈" FontSize="22" VerticalOptions="Center"/>
                <Label Text="Öz Biga Et Finans" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">

                <Border BackgroundColor="#1E293B" Stroke="Transparent" StrokeShape="RoundRectangle 24" Padding="24">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="BU AYIN TOPLAM CİROSU" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label x:Name="AylikCiroLabel" Text="₺0,00" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Border BackgroundColor="#0F172A" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,6" HorizontalOptions="Center">
                            <Label x:Name="AyLabel" Text="Mart 2026" TextColor="#3B82F6" FontSize="14" FontAttributes="Bold"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                    <Border Grid.Column="0" BackgroundColor="#16A34A" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="16">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Bugünkü Kar" TextColor="#DCFCE7" FontSize="11" FontAttributes="Bold"/>
                            <Label x:Name="GunlukKarLabel" Text="₺0,00" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#0F172A" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="16">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Satış Adedi" TextColor="#94A3B8" FontSize="11" FontAttributes="Bold"/>
                            <Label x:Name="GunlukSayiLabel" Text="0 Adet" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 20" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Bugünkü Ciro" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="GunlukCiroLabel" Text="₺0,00" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#334155" Opacity="0.3"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Aylık Toplam Kar" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="AylikKarLabel" Text="₺0,00" FontAttributes="Bold" FontSize="16" TextColor="#16A34A"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" Stroke="Transparent" StrokeShape="RoundRectangle 24" Padding="20">
            <VerticalStackLayout Spacing="12">
                <Button Text="📅 Satış Geçmişini Gör" BackgroundColor="#334155" TextColor="White" FontAttributes="Bold" HeightRequest="54" CornerRadius="14" Clicked="SatisGecmisiClicked"/>
                <Button Text="📥 Excel Raporu Al (Paylaş)" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" HeightRequest="54" CornerRadius="14" Clicked="ExcelAktarClicked"/>
                <Button Text="⬅ Ana Sayfaya Dön" BackgroundColor="Transparent" TextColor="#94A3B8" FontAttributes="Bold" HeightRequest="44" Clicked="GeriClicked"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>