<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.Raporlar"
             Title="Raporlar">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="📊 Raporlar"
               FontSize="22" FontAttributes="Bold"
               TextColor="#1A3A5C"/>

        <Button Text="📅 Bugünkü Satışlar"
                BackgroundColor="#2E75B6" TextColor="White"
                CornerRadius="8" HeightRequest="50"
                Clicked="BugunkuSatislarClicked"/>

        <Button Text="📋 Tüm Satışlar"
                BackgroundColor="#1A3A5C" TextColor="White"
                CornerRadius="8" HeightRequest="50"
                Clicked="TumSatislarClicked"/>

        <CollectionView x:Name="SatisListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Satis">
                    <VerticalStackLayout Padding="10" Spacing="4">
                        <Label Text="{Binding UrunAd}"
                               FontSize="16" FontAttributes="Bold"/>
                        <Label Text="{Binding Adet, StringFormat='Adet: {0}'}"
                               TextColor="Gray"/>
                        <Label Text="{Binding Fiyat, StringFormat='Fiyat: {0:C2}'}"
                               TextColor="#166534"/>
                        <Label Text="{Binding Tarih, StringFormat='Tarih: {0:dd/MM/yyyy HH:mm}'}"
                               TextColor="Gray" FontSize="12"/>
                        <BoxView HeightRequest="1" Color="#CCCCCC" Margin="0,5"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="⬅ Geri"
                BackgroundColor="Gray" TextColor="White"
                CornerRadius="8" HeightRequest="45"
                Clicked="GeriClicked"/>

    </VerticalStackLayout>
</ContentPage>