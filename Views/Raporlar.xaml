<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.Raporlar"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="📊 Raporlar"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryDark}"/>

            <!-- İstatistik Kartları -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0"
                                     BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                                     Padding="15" Spacing="4">
                    <Label Text="Bugünkü Ciro" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="GunlukCiroLabel" Text="₺0,00"
                           FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                                     Padding="15" Spacing="4">
                    <Label Text="Bugünkü Satış" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="GunlukSayiLabel" Text="0 adet"
                           FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                </VerticalStackLayout>
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0"
                         BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                         Padding="15" Spacing="4">
                    <Label Text="Bugünkü Kar" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="GunlukKarLabel" Text="₺0,00"
               FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                         BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                         Padding="15" Spacing="4">
                    <Label Text="Aylık Kar" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="AylikKarLabel" Text="₺0,00"
               FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0"
                                     BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                                     Padding="15" Spacing="4">
                    <Label Text="Aylık Ciro" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="AylikCiroLabel" Text="₺0,00"
                           FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1"
                                     BackgroundColor="{AppThemeBinding Light=#EEF4FF, Dark=#1E2A3A}"
                                     Padding="15" Spacing="4">
                    <Label Text="Ay" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                    <Label x:Name="AyLabel" Text=""
                           FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Satış Listesi Butonları -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="📅 Bugün"
                        Style="{StaticResource PrimaryBtn}"
                        Clicked="BugunkuSatislarClicked"/>
                <Button Grid.Column="1"
                        Text="📋 Tüm Satışlar"
                        BackgroundColor="{StaticResource PrimaryDark}"
                        TextColor="White" CornerRadius="10"
                        HeightRequest="52" FontSize="15" FontAttributes="Bold"
                        Clicked="TumSatislarClicked"/>
            </Grid>

            <!-- Satış Listesi Başlığı -->
            <Label x:Name="ListeBaslikLabel"
                   Text="" FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryDark}"
                   IsVisible="False"/>

            <!-- Satış Listesi -->
            <CollectionView x:Name="SatisListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Satis">
                        <Grid ColumnDefinitions="*,Auto" Padding="10" ColumnSpacing="8"
          BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
          Margin="0,2">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding UrunAd}"
                   FontSize="15" FontAttributes="Bold"/>
                                <Label Text="{Binding Tarih, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                   TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                                <Label Text="{Binding KasiyerAd, StringFormat='Kasiyer: {0}'}"
                   TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                                <Label Text="{Binding Fiyat, StringFormat='₺{0:N2}'}"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource Success}"
                   HorizontalOptions="End"/>
                                <Label Text="{Binding Adet, StringFormat='{0} adet'}"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="12" HorizontalOptions="End"/>
                                <Label Text="{Binding Kar, StringFormat='Kar: ₺{0:N2}'}"
                   TextColor="{StaticResource Primary}"
                   FontSize="12" HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Excel Butonu -->
            <Button Text="📥 Excel'e Aktar"
                    Style="{StaticResource SuccessBtn}"
                    Clicked="ExcelAktarClicked"/>

            <Button Text="⬅ Geri"
                    Style="{StaticResource GrayBtn}"
                    Clicked="GeriClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>