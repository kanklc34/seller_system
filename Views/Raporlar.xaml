<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.Raporlar"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,18,20,32" RowSpacing="14">

        <!-- Üst kısım -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12">

                <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 20"
                        Padding="20,16">
                    <Label Text="📊 Raporlar"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White"/>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Bugünkü Ciro"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="GunlukCiroLabel" Text="₺0,00"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Bugünkü Satış"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="GunlukSayiLabel" Text="0 adet"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Bugünkü Kar"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="GunlukKarLabel" Text="₺0,00"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Aylık Kar"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="AylikKarLabel" Text="₺0,00"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Aylık Ciro"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="AylikCiroLabel" Text="₺0,00"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16" Padding="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Ay"
                                   TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" FontSize="12"/>
                            <Label x:Name="AyLabel" Text=""
                                   FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boş alan (liste kaldırıldı, satış geçmişi ayrı sayfada) -->
        <BoxView Grid.Row="1" Color="Transparent"/>

        <!-- Alt butonlar -->
        <VerticalStackLayout Grid.Row="2" Spacing="10">

            <Border BackgroundColor="{StaticResource Accent}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 16"
                    Padding="0,16" HeightRequest="56">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="SatisGecmisiClicked"/>
                </Border.GestureRecognizers>
                <Label Text="📅 Satış Geçmişi"
                       TextColor="White" FontAttributes="Bold" FontSize="15"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Border BackgroundColor="{StaticResource Success}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 16"
                    Padding="0,16" HeightRequest="56">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="ExcelAktarClicked"/>
                </Border.GestureRecognizers>
                <Label Text="📥 Excel'e Aktar"
                       TextColor="White" FontAttributes="Bold" FontSize="15"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 16"
                    Padding="0,16" HeightRequest="56">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Border.GestureRecognizers>
                <Label Text="⬅ Geri"
                       TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                       FontAttributes="Bold" FontSize="15"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

        </VerticalStackLayout>
    </Grid>
</ContentPage>