<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Saller_System.Services"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="Saller_System.Views.Raporlar"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,32" Spacing="15">
            <Border BackgroundColor="{AppThemeBinding Light=#E31E24, Dark=#991B1B}" StrokeShape="RoundRectangle 20" Padding="20,16">
                <Label x:Name="RaporBaslikLabel" Text="Finans Raporu" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            </Border>

            <Border BackgroundColor="#1E293B" StrokeShape="RoundRectangle 24" Padding="24">
                <VerticalStackLayout Spacing="8">
                    <Label Text="BU AYIN TOPLAM CİROSU" TextColor="#D4AF37" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label x:Name="AylikCiroLabel" Text="₺0,00" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label x:Name="AyLabel" Text="" TextColor="#94A3B8" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border Grid.Column="0" BackgroundColor="#16A34A" StrokeShape="RoundRectangle 20" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Bugünkü Kar" TextColor="#DCFCE7" FontSize="11"/>
                        <Label x:Name="GunlukKarLabel" Text="₺0,00" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#1E293B}" StrokeShape="RoundRectangle 20" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Satış Adedi" TextColor="#D4AF37" FontSize="11"/>
                        <Label x:Name="GunlukSayiLabel" Text="0 Adet" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeShape="RoundRectangle 20" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Günlük Kasa / Nakit Özeti" FontSize="16" FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Satılan Et (Ciro)"/>
                        <Label Grid.Column="1" x:Name="GunlukCiroLabel" FontAttributes="Bold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Veresiye (Çıkan)" TextColor="#E31E24"/>
                        <Label Grid.Column="1" x:Name="VeresiyeCikanLabel" FontAttributes="Bold" TextColor="#E31E24"/>
                    </Grid>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Tahsilat (Giren)" TextColor="#16A34A"/>
                        <Label Grid.Column="1" x:Name="TahsilatGirenLabel" FontAttributes="Bold" TextColor="#16A34A"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#334155"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="NET KASA" FontAttributes="Bold"/>
                        <Label Grid.Column="1" x:Name="NetKasaLabel" FontSize="18" FontAttributes="Bold" TextColor="#16A34A"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="GÜNLÜK ÜRÜN SATIŞ DAĞILIMI" FontSize="12" FontAttributes="Bold" TextColor="#64748B" Margin="4,6,0,0"/>
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeShape="RoundRectangle 20" Padding="15">
                <microcharts:ChartView x:Name="SatisDagilimiChart" HeightRequest="220" />
            </Border>

            <Label Text="PERSONEL PERFORMANSI" FontSize="12" FontAttributes="Bold" TextColor="#64748B" Margin="4,6,0,0"/>
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" StrokeShape="RoundRectangle 20" Padding="15">
                <CollectionView x:Name="PersonelPerformansListesi" HeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:PersonelPerformans">
                            <Grid ColumnDefinitions="*, Auto" Padding="0,8">
                                <VerticalStackLayout>
                                    <Label Text="{Binding PersonelAdi}" FontAttributes="Bold"/>
                                    <Label Text="{Binding SatisSayisi, StringFormat='{0} Fiş'}" FontSize="11" TextColor="#94A3B8"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding ToplamCiro, StringFormat='₺{0:N2}'}" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" StrokeShape="RoundRectangle 24" Padding="20" Margin="0,6,0,0">
                <VerticalStackLayout Spacing="12">
                    <Button Text="📅 Satış Geçmişi" BackgroundColor="#D4AF37" TextColor="#0F172A" Clicked="SatisGecmisiClicked" HeightRequest="54" CornerRadius="14" FontAttributes="Bold"/>
                    <Button Text="📥 Excel Raporu Al" BackgroundColor="#16A34A" TextColor="White" Clicked="ExcelAktarClicked" HeightRequest="54" CornerRadius="14" FontAttributes="Bold"/>
                    <Button Text="⬅ Ana Sayfaya Dön" BackgroundColor="Transparent" TextColor="#94A3B8" Clicked="GeriClicked" HeightRequest="44"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>