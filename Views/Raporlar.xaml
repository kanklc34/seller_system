<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:Saller_System.Services"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="Saller_System.Views.Raporlar"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,32" Spacing="15">

            <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20,16">
                <Label x:Name="RaporBaslikLabel" Text="Finans Raporu" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            </Border>

            <Border BackgroundColor="#1E293B" StrokeShape="RoundRectangle 24" Padding="24">
                <VerticalStackLayout Spacing="8">
                    <Label Text="BU AYIN TOPLAM CİROSU" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label x:Name="AylikCiroLabel" Text="₺0,00" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Label x:Name="AyLabel" Text="" TextColor="#3B82F6" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border Grid.Column="0" BackgroundColor="#16A34A" StrokeShape="RoundRectangle 20" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Bugünkü Kar" TextColor="#DCFCE7" FontSize="11"/>
                        <Label x:Name="GunlukKarLabel" Text="₺0,00" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#1E293B}" StrokeShape="RoundRectangle 20" Padding="16">
                    <VerticalStackLayout>
                        <Label Text="Satış Adedi" TextColor="#94A3B8" FontSize="11"/>
                        <Label x:Name="GunlukSayiLabel" Text="0 Adet" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Günlük Kasa / Nakit Özeti" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" Margin="0,0,0,5"/>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Satılan Et (Ciro)" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"/>
                        <Label Grid.Column="1" x:Name="GunlukCiroLabel" Text="₺0,00" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Veresiye (Kasadan Çıkan)" TextColor="#E31E24"/>
                        <Label Grid.Column="1" x:Name="VeresiyeCikanLabel" Text="-₺0,00" FontAttributes="Bold" TextColor="#E31E24"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Tahsilat (Kasaya Giren)" TextColor="#16A34A"/>
                        <Label Grid.Column="1" x:Name="TahsilatGirenLabel" Text="+₺0,00" FontAttributes="Bold" TextColor="#16A34A"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" Margin="0,5"/>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="NET KASA (Sıcak Para)" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                        <Label Grid.Column="1" x:Name="NetKasaLabel" Text="₺0,00" FontSize="18" FontAttributes="Bold" TextColor="#16A34A"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="GÜNLÜK ÜRÜN SATIŞ DAĞILIMI" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" Margin="4,6,0,0"/>
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="15">
                <microcharts:ChartView x:Name="SatisDagilimiChart" HeightRequest="220" />
            </Border>

            <Label Text="PERSONEL PERFORMANSI" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" Margin="4,6,0,0"/>
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeThickness="1" StrokeShape="RoundRectangle 20" Padding="15">
                <CollectionView x:Name="PersonelPerformansListesi" HeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:PersonelPerformans">
                            <Grid ColumnDefinitions="*, Auto" Padding="0,8">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding PersonelAdi}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                                    <Label Text="{Binding SatisSayisi, StringFormat='{0} Fiş'}" FontSize="11" TextColor="#94A3B8"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding ToplamCiro, StringFormat='₺{0:N2}'}" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" Stroke="Transparent" StrokeShape="RoundRectangle 24" Padding="20" Margin="0,6,0,0">
                <VerticalStackLayout Spacing="12">
                    <Button Text="📅 Satış Geçmişi" BackgroundColor="#334155" TextColor="White" Clicked="SatisGecmisiClicked" HeightRequest="54" CornerRadius="14"/>
                    <Button Text="📥 Excel Raporu Al" BackgroundColor="#16A34A" TextColor="White" Clicked="ExcelAktarClicked" HeightRequest="54" CornerRadius="14"/>
                    <Button Text="⬅ Ana Sayfaya Dön" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" Clicked="GeriClicked" HeightRequest="44"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>