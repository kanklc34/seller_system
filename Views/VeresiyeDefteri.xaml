<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             xmlns:models="clr-namespace:Saller_System.Models" 
             x:Class="Saller_System.Views.VeresiyeDefteri" 
             Shell.NavBarIsVisible="False" 
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,18,20,10" RowSpacing="14">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <Border BackgroundColor="{AppThemeBinding Light=#E31E24, Dark=#991B1B}" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="10,8" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Border.GestureRecognizers>
                <Label Text="⬅" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Veresiye Defteri" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Border Grid.Column="0" Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#374151}" StrokeShape="RoundRectangle 14" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="12,4" HeightRequest="48">
                <SearchBar x:Name="MusteriAraBar" Placeholder="Müşteri ara..." TextChanged="MusteriAraTextChanged" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" PlaceholderColor="#94A3B8"/>
            </Border>
            <Button Grid.Column="1" Text="➕ Yeni" BackgroundColor="#E31E24" TextColor="White" FontAttributes="Bold" CornerRadius="12" WidthRequest="80" Clicked="YeniMusteriClicked"/>
        </Grid>

        <CollectionView Grid.Row="2" x:Name="MusterilerListesi">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="0,50">
                    <Label Text="📒" FontSize="50" HorizontalOptions="Center" Opacity="0.3"/>
                    <Label Text="Kayıtlı müşteri bulunmuyor." TextColor="#94A3B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Musteri">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" 
                            Padding="16" Margin="0,0,0,12" StrokeShape="RoundRectangle 16">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="10">

                            <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="2">
                                <Label Text="{Binding AdSoyad}" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" FontAttributes="Bold" FontSize="18"/>
                                <Label Text="İşlem yapmak için seçin" FontSize="12" TextColor="#64748B"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" HorizontalOptions="End">
                                <Label Text="{Binding ToplamBorc, StringFormat='₺{0:N2}'}" TextColor="{Binding DurumRengi}" FontAttributes="Bold" FontSize="20"/>
                                <Label Text="{Binding DurumMetni}" TextColor="{Binding DurumRengi}" FontSize="11" HorizontalOptions="End"/>
                            </VerticalStackLayout>

                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*, *, *" ColumnSpacing="8" Margin="0,5,0,0">
                                <Button Grid.Column="0" Text="Ekstre" Clicked="EkstreClicked" CommandParameter="{Binding .}"
                                        BackgroundColor="#F1F5F9" TextColor="#475569" HeightRequest="38" FontSize="12" CornerRadius="8"/>

                                <Button Grid.Column="1" Text="Tahsilat" Clicked="TahsilatAlClicked" CommandParameter="{Binding .}"
                                        BackgroundColor="#16A34A" TextColor="White" HeightRequest="38" FontSize="12" CornerRadius="8"/>

                                <Button Grid.Column="2" Text="Kapat" Clicked="HesabiKapatClicked" CommandParameter="{Binding .}"
                                        BackgroundColor="#3B82F6" TextColor="White" HeightRequest="38" FontSize="12" CornerRadius="8"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>