<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.SepetSayfa"
             Title="Sepet"
             BackgroundColor="{StaticResource PageBg}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="🛒 Sepet"
               FontSize="22" FontAttributes="Bold"
               TextColor="{StaticResource PrimaryDark}"/>

        <CollectionView x:Name="SepetListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SepetItem">
                    <Grid ColumnDefinitions="*,Auto" Padding="10" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding Urun.Ad}"
                                   FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Adet, StringFormat='Adet: {0}'}"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label Text="{Binding Toplam, StringFormat='₺{0:N2}'}"
                                   TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="🗑️"
                                BackgroundColor="{StaticResource Danger}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="40" WidthRequest="44"
                                CommandParameter="{Binding .}"
                                Clicked="ItemSilClicked"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="Toplam:"
                   FontSize="18" FontAttributes="Bold"/>
            <Label Grid.Column="1" x:Name="ToplamLabel"
                   Text="₺0,00" FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Success}"/>
        </Grid>

        <Button Text="✅ Satışı Tamamla"
                Style="{StaticResource SuccessBtn}"
                Clicked="SatisiTamamlaClicked"/>

        <Button Text="🗑️ Sepeti Temizle"
                Style="{StaticResource DangerBtn}"
                Clicked="SepetiTemizleClicked"/>

        <Button Text="⬅ Geri"
                Style="{StaticResource GrayBtn}"
                Clicked="GeriClicked"/>

    </VerticalStackLayout>
</ContentPage>