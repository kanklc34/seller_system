<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.SepetSayfa"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,18,20,20" RowSpacing="12">

        <Border Grid.Row="0" 
                BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" 
                Stroke="Transparent" 
                StrokeShape="RoundRectangle 20" 
                Padding="20,16">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="🛒 Satış Sepeti" FontSize="22" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Temizle" TextColor="#FCA5A5" VerticalOptions="Center" FontSize="13">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SepetiTemizleTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <CollectionView Grid.Row="1" x:Name="SepetListesi">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="Empty Basket" FontSize="50" HorizontalOptions="Center" Opacity="0.3"/>
                    <Label Text="Sepet şu an boş." TextColor="#94A3B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SepetItem">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" 
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" 
                            StrokeThickness="1" 
                            StrokeShape="RoundRectangle 18" 
                            Padding="16" 
                            Margin="0,6">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="{Binding Urun.Ad}" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="15">
                                    <Label Text="{Binding Adet, StringFormat='Miktar: {0}'}" FontSize="13" TextColor="#94A3B8"/>
                                    <Label Grid.Column="1" Text="{Binding Toplam, StringFormat='₺{0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="#16A34A"/>
                                </Grid>
                            </VerticalStackLayout>

                            <Button Grid.Column="1" 
                                    Text="🗑️" 
                                    BackgroundColor="#FEE2E2" 
                                    TextColor="#B91C1C" 
                                    WidthRequest="50" 
                                    HeightRequest="50" 
                                    CornerRadius="14" 
                                    Clicked="ItemSilTapped" 
                                    CommandParameter="{Binding .}"
                                    Padding="0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2" 
                BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}" 
                Stroke="Transparent" 
                StrokeShape="RoundRectangle 24" 
                Padding="24"
                Margin="0,10,0,0">
            <VerticalStackLayout Spacing="18">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="GENEL TOPLAM" TextColor="#94A3B8" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="ToplamLabel" Text="₺0,00" FontSize="26" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#334155" HorizontalOptions="Fill"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" 
                            Text="⬅ Geri" 
                            BackgroundColor="#334155" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            HeightRequest="56" 
                            CornerRadius="16" 
                            Clicked="GeriClicked"/>

                    <Button Grid.Column="1" 
                            Text="ÖDEME AL" 
                            BackgroundColor="#16A34A" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            HeightRequest="56" 
                            CornerRadius="16" 
                            Clicked="SatisiTamamlaTapped"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>