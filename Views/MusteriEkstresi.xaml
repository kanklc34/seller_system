<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Saller_System.Views.MusteriEkstresi" Title="Hesap Ekstresi" Shell.NavBarIsVisible="False" BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">
    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Border BackgroundColor="{AppThemeBinding Light=#E31E24, Dark=#991B1B}" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="10,8" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Border.GestureRecognizers>
                <Label Text="⬅" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Müşteri Ekstresi" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" VerticalOptions="Center" Margin="15,0,0,0"/>
        </Grid>
        <VerticalStackLayout Grid.Row="1" Spacing="15">
            <Label x:Name="IsimLabel" Text="..." FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
            <Border Stroke="#E31E24" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="15">
                <Label x:Name="DurumLabel" Text="..." FontSize="16" FontAttributes="Bold" />
            </Border>
            <Label Text="İşlem Geçmişi" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" Margin="0,10,0,5"/>
            <CollectionView x:Name="IslemlerListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Aciklama}" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                                    <Label Text="{Binding Tarih, StringFormat='{0:dd.MM.yyyy - HH:mm}'}" FontSize="12" TextColor="#94A3B8" Margin="0,2,0,0"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding Tutar, StringFormat='{0:N2} ₺'}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentPage>