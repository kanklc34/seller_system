<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.KullaniciYonetimi"
             Title="Kullanıcı Yönetimi">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="👥 Kullanıcı Yönetimi"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#1A3A5C"/>

            <!-- Yeni Kullanıcı Ekle -->
            <Label Text="Yeni Kullanıcı Ekle"
                   FontSize="16" FontAttributes="Bold" TextColor="#2E75B6"/>

            <Entry x:Name="YeniKullaniciAdiEntry" Placeholder="Kullanıcı adı"/>
            <Entry x:Name="YeniSifreEntry" Placeholder="Şifre" IsPassword="True"/>

            <Picker x:Name="RolPicker" Title="Rol Seç">
                <Picker.Items>
                    <x:String>Admin</x:String>
                    <x:String>Yonetici</x:String>
                    <x:String>Calisan</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="➕ Kullanıcı Ekle"
                    BackgroundColor="#166534" TextColor="White"
                    CornerRadius="8" HeightRequest="50"
                    Clicked="KullaniciEkleClicked"/>

            <BoxView HeightRequest="1" Color="#CCCCCC" Margin="0,10"/>

            <!-- Kullanıcı Listesi -->
            <Label Text="Mevcut Kullanıcılar"
                   FontSize="16" FontAttributes="Bold" TextColor="#2E75B6"/>

            <CollectionView x:Name="KullaniciListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Kullanici">
                        <Grid ColumnDefinitions="*,Auto" Padding="10" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding KullaniciAdi}"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Rol}"
                                       TextColor="Gray" FontSize="13"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="🗑️ Sil"
                                    BackgroundColor="#DC2626" TextColor="White"
                                    CornerRadius="6" HeightRequest="40"
                                    CommandParameter="{Binding .}"
                                    Clicked="KullaniciSilClicked"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="⬅ Geri"
                    BackgroundColor="Gray" TextColor="White"
                    CornerRadius="8" HeightRequest="45"
                    Clicked="GeriClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>