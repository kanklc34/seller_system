<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.KullaniciYonetimi"
             Title="Kullanıcı Yönetimi"
             BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#0F172A}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="12">

        <!-- Üst — başlık ve yeni kullanıcı ekle -->
        <ScrollView Grid.Row="0" Orientation="Vertical">
            <VerticalStackLayout Spacing="12">
                <Label Text="👥 Kullanıcı Yönetimi"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"/>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        StrokeShape="RoundRectangle 12" Stroke="Transparent" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Yeni Kullanıcı Ekle" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>
                        <Entry x:Name="YeniKullaniciAdiEntry" Placeholder="Kullanıcı adı"/>
                        <Entry x:Name="YeniSifreEntry" Placeholder="Şifre" IsPassword="True"/>
                        <Picker x:Name="RolPicker" Title="Rol Seç"
                                TextColor="{AppThemeBinding Light=#0F172A, Dark=#F1F5F9}"
                                TitleColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}">
                            <Picker.Items>
                                <x:String>Admin</x:String>
                                <x:String>Yonetici</x:String>
                                <x:String>Calisan</x:String>
                            </Picker.Items>
                        </Picker>
                        <Button Text="➕ Kullanıcı Ekle"
                                Style="{StaticResource SuccessBtn}"
                                Clicked="KullaniciEkleClicked"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Mevcut Kullanıcılar" FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Orta — kullanıcı listesi -->
        <CollectionView Grid.Row="1" x:Name="KullaniciListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Kullanici">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            Padding="12" Margin="0,3">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding KullaniciAdi}"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Rol}"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                                       FontSize="13"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="🗑️ Sil"
                                    Style="{StaticResource DangerBtn}"
                                    HeightRequest="40" WidthRequest="80"
                                    CommandParameter="{Binding .}"
                                    Clicked="KullaniciSilClicked"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Alt — geri butonu -->
        <Button Grid.Row="2" Text="⬅ Geri"
                Style="{StaticResource GrayBtn}"
                Clicked="GeriClicked"/>

    </Grid>
</ContentPage>