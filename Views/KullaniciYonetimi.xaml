<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.KullaniciYonetimi"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,18,20,32" RowSpacing="14">

        <!-- Üst — başlık ve yeni kullanıcı ekle -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12">

                <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 20"
                        Padding="20,16">
                    <Label Text="👥 Kullanıcı Yönetimi"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White"/>
                </Border>

                <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Yeni Kullanıcı Ekle"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>

                        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#0F172A}"
                                Padding="14,4" HeightRequest="54">
                            <Entry x:Name="YeniKullaniciAdiEntry"
                                   Placeholder="Kullanıcı adı"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#0F172A}"
                                Padding="14,4" HeightRequest="54">
                            <Entry x:Name="YeniSifreEntry"
                                   Placeholder="Şifre"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#374151}"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#0F172A}"
                                Padding="14,4" HeightRequest="54">
                            <Picker x:Name="RolPicker"
                                    Title="Rol Seç"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#0F172A, Dark=#F1F5F9}"
                                    TitleColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}">
                                <Picker.Items>
                                    <x:String>Admin</x:String>
                                    <x:String>Yonetici</x:String>
                                    <x:String>Calisan</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>

                        <Border BackgroundColor="{StaticResource Success}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 14"
                                Padding="0,16" HeightRequest="54">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="KullaniciEkleClicked"/>
                            </Border.GestureRecognizers>
                            <Label Text="➕ Kullanıcı Ekle"
                                   TextColor="White" FontAttributes="Bold" FontSize="15"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Mevcut Kullanıcılar"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Kullanıcı listesi -->
        <CollectionView Grid.Row="1" x:Name="KullaniciListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Kullanici">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="16" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding KullaniciAdi}"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Rol}"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                                       FontSize="13"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="12,0"
                                    HeightRequest="44" WidthRequest="70"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        CommandParameter="{Binding .}"
                                        Tapped="KullaniciSilClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="🗑️ Sil"
                                       TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}"
                                       FontAttributes="Bold" FontSize="13"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Geri -->
        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 16"
                Padding="0,16" HeightRequest="56">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="GeriClicked"/>
            </Border.GestureRecognizers>
            <Label Text="⬅ Geri"
                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                   FontAttributes="Bold" FontSize="15"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

    </Grid>
</ContentPage>