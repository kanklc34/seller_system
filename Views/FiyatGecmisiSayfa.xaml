<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.FiyatGecmisiSayfa"
             Title="Fiyat Geçmişi">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="📈 Fiyat Geçmişi"
               FontSize="22" FontAttributes="Bold"
               TextColor="{StaticResource PrimaryDark}"/>

        <Label x:Name="UrunAdLabel"
               FontSize="16" TextColor="{StaticResource TextSecondary}"/>

        <CollectionView x:Name="GecmisListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FiyatGecmisi">
                    <Grid ColumnDefinitions="*,*,*" Padding="10" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Eski Fiyat"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label Text="{Binding EskiFiyat, StringFormat='₺{0:N2}'}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Danger}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Yeni Fiyat"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label Text="{Binding YeniFiyat, StringFormat='₺{0:N2}'}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                            <Label Text="{Binding Tarih, StringFormat='{0:dd/MM/yy HH:mm}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label Text="{Binding DegistirenKullanici}"
                                   FontSize="12"
                                   TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="⬅ Geri"
                Style="{StaticResource GrayBtn}"
                Clicked="GeriClicked"/>

    </VerticalStackLayout>
</ContentPage>