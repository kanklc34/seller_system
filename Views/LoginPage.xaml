<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Saller_System.Views.LoginPage"
             BackgroundColor="#0B1220">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid VerticalOptions="Center" Padding="30">
        <VerticalStackLayout Spacing="30" WidthRequest="340" HorizontalOptions="Center">

            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="ÖZ BİGA ET" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="POS YÖNETİM SİSTEMİ" FontSize="14" TextColor="#94A3B8" CharacterSpacing="2" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Border BackgroundColor="#1E293B" Stroke="Transparent" StrokeShape="RoundRectangle 24" Padding="25">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Personel Girişi" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,10"/>

                    <Border Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" HeightRequest="56" Padding="15,0">
                        <Entry x:Name="KullaniciAdiEntry" Placeholder="Kullanıcı Adı" PlaceholderColor="#475569" TextColor="White" VerticalOptions="Center"/>
                    </Border>

                    <Border Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" HeightRequest="56" Padding="15,0">
                        <Entry x:Name="SifreEntry" Placeholder="Şifre" IsPassword="True" PlaceholderColor="#475569" TextColor="White" VerticalOptions="Center"/>
                    </Border>

                    <Button Text="SİSTEME GİRİŞ YAP" Clicked="GirisYapClicked" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" HeightRequest="54" CornerRadius="12" Margin="0,10,0,0"/>

                    <Border x:Name="HataBorder" IsVisible="False" BackgroundColor="#451A1A" Stroke="Transparent" StrokeShape="RoundRectangle 10" Padding="10">
                        <Label x:Name="HataLabel" TextColor="#FCA5A5" FontSize="13" HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Label Text="© 2026 Öz Biga Et Yazılım" TextColor="#475569" FontSize="11" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>