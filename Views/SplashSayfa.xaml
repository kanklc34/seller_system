<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Saller_System.Views.SplashSayfa"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
        <Image Source="logo.jpg" WidthRequest="220" HeightRequest="220" HorizontalOptions="Center"/>
        <Label Text="Öz Biga Et" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
        <Label Text="Kasap &amp; Şarküteri Sistemi" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#D4AF37"/>
        <ActivityIndicator IsRunning="True" Color="#E31E24" HorizontalOptions="Center" Margin="0,15,0,0"/>
    </VerticalStackLayout>
</ContentPage>