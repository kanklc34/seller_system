<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Saller_System.Views.AnaSayfa"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              Padding="20,18,20,0"
              ColumnDefinitions="*,Auto">

            <Border x:Name="AyarlarBtn"
                    Grid.Column="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Padding="12"
                    HorizontalOptions="End"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AyarlarClicked" />
                </Border.GestureRecognizers>

                <Label Text="⚙️"
                       FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16,20,32" Spacing="18">

                <Border BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 28"
                        Padding="25">

                    <VerticalStackLayout Spacing="18">

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Kasap Pro"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White" />

                                <Label x:Name="HosgeldinLabel"
                                       Text="Hoş geldiniz"
                                       FontSize="14"
                                       TextColor="#CBD5E1" />
                            </VerticalStackLayout>

                            <Border x:Name="GunlukOzetBadge"
                                    Grid.Column="1"
                                    BackgroundColor="#1E293B"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12,8"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start">
                                <Label Text="Günlük Özet"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#E2E8F0" />
                            </Border>
                        </Grid>

                        <Grid x:Name="OzetBilgiGrid"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">

                            <Border BackgroundColor="#1E293B"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,8"
                                    HeightRequest="55">
                                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                    <Label Text="Satış"
                                           FontSize="11"
                                           TextColor="#94A3B8" />
                                    <Label Text="24"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#1E293B"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,8"
                                    HeightRequest="55">
                                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                    <Label Text="Kilo"
                                           FontSize="11"
                                           TextColor="#94A3B8" />
                                    <Label Text="128 kg"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2"
                                    BackgroundColor="#1E293B"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,8"
                                    HeightRequest="55">
                                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                    <Label Text="Ciro"
                                           FontSize="11"
                                           TextColor="#94A3B8" />
                                    <Label Text="₺8.450"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Ana İşlemler"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="14">

                        <Border Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light=#2563EB, Dark=#1D4ED8}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 24"
                                Padding="18"
                                HeightRequest="170">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="BarkodOkutClicked" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8"
                                                 VerticalOptions="Start">
                                <Label Text="📷"
                                       FontSize="34" />
                                <Label Text="Barkod Okut"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Etiketi tara ve satışı sisteme aktar"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2"
                                       TextColor="#DBEAFE" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light=#16A34A, Dark=#15803D}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 24"
                                Padding="18"
                                HeightRequest="170">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="UrunListesiClicked" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8"
                                                 VerticalOptions="Start">
                                <Label Text="📦"
                                       FontSize="34" />
                                <Label Text="Ürün Listesi"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="Kayıtlı ürünleri görüntüle ve yönet"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2"
                                       TextColor="#DCFCE7" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="YonetimBolumu"
                                     Spacing="12">
                    <Label Text="Yönetim"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="14"
                          RowSpacing="14">

                        <Border x:Name="RaporlarBtn"
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 22"
                                Padding="18"
                                HeightRequest="150">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="RaporlarClicked" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8"
                                                 VerticalOptions="Start">
                                <Label Text="📊"
                                       FontSize="28" />
                                <Label Text="Raporlar"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                <Label Text="Satış, ciro ve en çok satan ürünler"
                                       FontSize="12"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="KullaniciYonetimiBtn"
                                Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 22"
                                Padding="18"
                                HeightRequest="150">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="KullaniciYonetimiClicked" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8"
                                                 VerticalOptions="Start">
                                <Label Text="👥"
                                       FontSize="28" />
                                <Label Text="Kullanıcılar"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" />
                                <Label Text="Personel ve yetki işlemlerini yönet"
                                       FontSize="12"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <Button Text="Çıkış Yap"
                        HeightRequest="60"
                        CornerRadius="18"
                        FontSize="15"
                        FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                        TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}"
                        Clicked="CikisClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>