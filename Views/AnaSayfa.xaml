<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Saller_System.Views.AnaSayfa"
             Title="Ana Sayfa"
             BackgroundColor="{StaticResource PageBg}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12" VerticalOptions="Center">

            <Label Text="🛒 Saller System"
                   FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource PrimaryDark}"/>

            <Label x:Name="HosgeldinLabel"
                   FontSize="14" HorizontalOptions="Center"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="0,0,0,20"/>

            <Button x:Name="BarkodBtn"
                    Text="📷  Barkod Okut"
                    Style="{StaticResource PrimaryBtn}"
                    Clicked="BarkodOkutClicked"/>

            <Button x:Name="UrunListesiBtn"
                    Text="📦  Ürün Listesi"
                    Style="{StaticResource SuccessBtn}"
                    Clicked="UrunListesiClicked"/>

            <Button x:Name="RaporlarBtn"
                    Text="📊  Raporlar"
                    BackgroundColor="{StaticResource PrimaryDark}"
                    TextColor="White" CornerRadius="10"
                    HeightRequest="52" FontSize="15" FontAttributes="Bold"
                    Clicked="RaporlarClicked"/>

            <Button x:Name="KullaniciYonetimiBtn"
                    Text="👥  Kullanıcı Yönetimi"
                    BackgroundColor="#7C3AED"
                    TextColor="White" CornerRadius="10"
                    HeightRequest="52" FontSize="15" FontAttributes="Bold"
                    Clicked="KullaniciYonetimiClicked"/>

            <!-- Dark mode toggle -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="12" Margin="0,16,0,0">
                <Label Text="🌙 Koyu Tema"
                       VerticalOptions="Center"
                       TextColor="{StaticResource TextSecondary}"/>
                <Switch x:Name="DarkModeSwitch"
                        Toggled="DarkModeToggled"/>
            </HorizontalStackLayout>
            <Button Text="⚙️  Ayarlar"
        BackgroundColor="#6B7280" TextColor="White"
        CornerRadius="10" HeightRequest="52"
        FontSize="15" FontAttributes="Bold"
        Clicked="AyarlarClicked"/>
            <Button Text="🚪  Çıkış"
                    Style="{StaticResource DangerBtn}"
                    Margin="0,8,0,0"
                    Clicked="CikisClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>