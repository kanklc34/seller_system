<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Saller_System.Views.ToptanSatis" Shell.NavBarIsVisible="False" BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">
    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="20" RowSpacing="15">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Border BackgroundColor="{AppThemeBinding Light=#E31E24, Dark=#991B1B}" Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="10,8" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Border.GestureRecognizers>
                <Label Text="⬅" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Toptan Satış" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}" VerticalOptions="Center" Margin="15,0,0,0"/>
        </Grid>
        <VerticalStackLayout Grid.Row="1" Spacing="5">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                    <Picker x:Name="MusteriPicker" ItemDisplayBinding="{Binding SirketAdi}" Title="Firma Seçiniz..." TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                </Border>
                <Button Grid.Column="1" Text="+ Yeni" Clicked="YeniMusteri_Clicked" BackgroundColor="#D4AF37" CornerRadius="8" TextColor="#0F172A" FontAttributes="Bold"/>
            </Grid>
        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                <SearchBar x:Name="UrunAramaBar" Placeholder="Ürün Ara..." TextChanged="UrunArama_TextChanged" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
            </Border>
            <CollectionView x:Name="UrunlerListesi" HeightRequest="120" SelectionMode="Single" SelectionChanged="UrunSecildi" IsVisible="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding Ad}" Padding="15" BackgroundColor="#1E293B" TextColor="White" Margin="0,2"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Grid ColumnDefinitions="*,*,*, Auto" ColumnSpacing="8" Margin="0,10,0,0">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Miktar" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"/>
                    <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                        <Entry x:Name="MiktarEntry" Keyboard="Numeric" Placeholder="Kg/Ad" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Maliyet(₺)" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"/>
                    <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                        <Entry x:Name="MaliyetEntry" Keyboard="Numeric" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <Label Text="Satış(₺)" FontSize="11" TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"/>
                    <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                        <Entry x:Name="SatisFiyatiEntry" Keyboard="Numeric" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                    </Border>
                </VerticalStackLayout>
                <Button Grid.Column="3" Text="Ekle" Clicked="SepeteEkle_Clicked" BackgroundColor="#16A34A" CornerRadius="8" FontAttributes="Bold" TextColor="White" VerticalOptions="End" HeightRequest="45" WidthRequest="70"/>
            </Grid>
            <Label x:Name="SecilenUrunLabel" Text="Seçilen: (Yok)" TextColor="#E31E24" FontSize="13" FontAttributes="Bold" Margin="0,5,0,0"/>
            <Label Text="Satılacaklar Listesi" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}" Margin="0,10,0,0"/>
            <CollectionView x:Name="SepetListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" StrokeShape="RoundRectangle 8" Padding="12" Margin="0,3" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}">
                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <Label Text="{Binding UrunAd}" VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=White}"/>
                                <Label Grid.Column="1" Text="{Binding Adet, StringFormat='{0} Kg/Ad'}" VerticalOptions="Center" Margin="15,0" TextColor="#94A3B8"/>
                                <Label Grid.Column="2" Text="{Binding Fiyat, StringFormat='₺{0:N2}'}" TextColor="#16A34A" FontAttributes="Bold" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="3" Spacing="10">
            <Label x:Name="ToplamTutarLabel" Text="Toplam: ₺0.00" FontSize="22" FontAttributes="Bold" HorizontalOptions="End" TextColor="#E31E24"/>
            <Button Text="TOPTAN SATIŞI ONAYLA" Clicked="SatisTamamla_Clicked" BackgroundColor="#E31E24" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" FontSize="18" TextColor="White"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>