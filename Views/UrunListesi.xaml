<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.UrunListesi"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0B1220}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20,18,20,32" RowSpacing="12">

        <!-- Başlık -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light=#0F172A, Dark=#111827}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 20"
                Padding="20,16">
            <Label Text="📦 Ürün Listesi"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"/>
        </Border>

        <!-- Yeni Ürün Ekle -->
        <Border Grid.Row="1"
                x:Name="YeniUrunBtn"
                BackgroundColor="{StaticResource Success}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 16"
                Padding="0,16" HeightRequest="54">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="YeniUrunClicked"/>
            </Border.GestureRecognizers>
            <Label Text="+ Yeni Ürün Ekle"
                   TextColor="White" FontAttributes="Bold"
                   FontSize="15"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- Ürün Listesi -->
        <CollectionView Grid.Row="2" x:Name="UrunlerListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Urun">
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E293B}"
                            Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="16" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding Ad}"
                                       FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Barkod, StringFormat='Barkod: {0}'}"
                                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                                       FontSize="12"/>
                                <Label TextColor="{StaticResource Success}" FontAttributes="Bold" FontSize="14">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding GramajliMi}"
                                                     Value="True">
                                            <Setter Property="Text"
                                                    Value="{Binding KgFiyati, StringFormat='₺{0:N2}/kg'}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding GramajliMi}"
                                                     Value="False">
                                            <Setter Property="Text"
                                                    Value="{Binding Fiyat, StringFormat='₺{0:N2}'}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Fiyat Geçmişi -->
                            <Border Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    HeightRequest="40" WidthRequest="44"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        CommandParameter="{Binding .}"
                                        Tapped="FiyatGecmisiClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="📈"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Düzenle -->
                            <Border Grid.Column="2"
                                    BackgroundColor="{StaticResource Primary}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    HeightRequest="40" WidthRequest="44"
                                    VerticalOptions="Center"
                                    IsVisible="{Binding Source={x:Reference ThisPage}, Path=YoneticiMi}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        CommandParameter="{Binding .}"
                                        Tapped="UrunDuzenleClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="✏️"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Sil -->
                            <Border Grid.Column="3"
                                    BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 10"
                                    HeightRequest="40" WidthRequest="44"
                                    VerticalOptions="Center"
                                    IsVisible="{Binding Source={x:Reference ThisPage}, Path=YoneticiMi}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        CommandParameter="{Binding .}"
                                        Tapped="UrunSilClicked"/>
                                </Border.GestureRecognizers>
                                <Label Text="🗑️"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Geri -->
        <Border Grid.Row="3"
                BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#1E293B}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 16"
                Padding="0,16" HeightRequest="56">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="GeriClicked"/>
            </Border.GestureRecognizers>
            <Label Text="⬅ Geri"
                   TextColor="{AppThemeBinding Light=#475569, Dark=#CBD5E1}"
                   FontAttributes="Bold" FontSize="15"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

    </Grid>
</ContentPage>