<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.UrunListesi"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B1220">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20,10,20,10" RowSpacing="15">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
            <Label Text="⬅" FontSize="24" TextColor="White">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Label.GestureRecognizers>
            </Label>
            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5">
                <Label Text="Öz Biga Et" FontSize="20" FontAttributes="Bold" TextColor="White"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" x:Name="TarihLabel" TextColor="#94A3B8" FontSize="12" VerticalOptions="Center"/>
        </Grid>

        <Border Grid.Row="1" x:Name="YeniUrunPaneli" BackgroundColor="#1E293B" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20">
            <VerticalStackLayout Spacing="10">
                <Border Stroke="#374151" StrokeShape="RoundRectangle 8" BackgroundColor="#0F172A" Padding="10,0" HeightRequest="45">
                    <Entry x:Name="AdEntry" Placeholder="Ürün Adı" TextColor="White" VerticalOptions="Center"/>
                </Border>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Border Grid.Column="0" Stroke="#374151" StrokeShape="RoundRectangle 8" BackgroundColor="#0F172A" Padding="10,0" HeightRequest="45">
                        <Entry x:Name="BarkodEntry" Placeholder="Barkod" TextColor="White" Keyboard="Numeric"/>
                    </Border>
                    <Border Grid.Column="1" Stroke="#374151" StrokeShape="RoundRectangle 8" BackgroundColor="#0F172A" Padding="10,0" HeightRequest="45">
                        <Entry x:Name="KategoriEntry" Placeholder="Kategori" TextColor="White"/>
                    </Border>
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="⚖️ Gramajlı" TextColor="#CBD5E1" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" x:Name="GramajliSwitch" OnColor="#e31e24"/>
                </Grid>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Border Grid.Column="0" Stroke="#374151" StrokeShape="RoundRectangle 8" BackgroundColor="#0F172A" Padding="10,0" HeightRequest="45">
                        <Entry x:Name="FiyatEntry" Placeholder="Satış ₺" TextColor="White" Keyboard="Numeric"/>
                    </Border>
                    <Border Grid.Column="1" Stroke="#374151" StrokeShape="RoundRectangle 8" BackgroundColor="#0F172A" Padding="10,0" HeightRequest="45">
                        <Entry x:Name="AlisFiyatiEntry" Placeholder="Alış ₺" TextColor="White" Keyboard="Numeric"/>
                    </Border>
                </Grid>
                <Button Text="Kaydet" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" HeightRequest="45" Clicked="KaydetClicked"/>
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Border Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#1E293B" Padding="10,0" HeightRequest="45">
                <SearchBar x:Name="UrunAraBar" Placeholder="Ürün ara..." TextChanged="UrunAraTextChanged" BackgroundColor="Transparent" TextColor="White"/>
            </Border>

            <CollectionView x:Name="UrunlerListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Urun">
                        <Border BackgroundColor="#1E293B" Padding="15" Margin="0,0,0,8" StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">

                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Ad}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Fiyat, StringFormat='₺{0:N2}'}" TextColor="#16A34A"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="1" 
                                        Text="✏️" 
                                        Clicked="UrunDuzenleClicked" 
                                        CommandParameter="{Binding .}" 
                                        WidthRequest="40" 
                                        BackgroundColor="#16A34A"
                                        IsVisible="{Binding Source={x:Reference ThisPage}, Path=IsYonetici}"/>

                                <Button Grid.Column="2" 
                                        Text="🗑️" 
                                        Clicked="UrunSilClicked" 
                                        CommandParameter="{Binding .}" 
                                        WidthRequest="40" 
                                        BackgroundColor="#e31e24"
                                        IsVisible="{Binding Source={x:Reference ThisPage}, Path=IsYonetici}"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

    </Grid>
</ContentPage>