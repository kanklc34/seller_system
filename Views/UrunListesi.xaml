<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.UrunListesi"
             x:Name="ThisPage"
             Title="Ürün Listesi"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="📦 Ürün Listesi"
               FontSize="22" FontAttributes="Bold"
               TextColor="{StaticResource PrimaryDark}"/>

        <Button x:Name="YeniUrunBtn"
                Text="+ Yeni Ürün Ekle"
                Style="{StaticResource SuccessBtn}"
                Clicked="YeniUrunClicked"/>

        <CollectionView x:Name="UrunlerListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Urun">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          Padding="10" ColumnSpacing="8"
                          BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding Ad}"
                                   FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Barkod, StringFormat='Barkod: {0}'}"
                                   TextColor="{StaticResource TextSecondary}"/>
                            <Label TextColor="{StaticResource Success}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding GramajliMi}"
                                                 Value="True">
                                        <Setter Property="Text"
                                                Value="{Binding KgFiyati, StringFormat='₺{0:N2}/kg'}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding GramajliMi}"
                                                 Value="False">
                                        <Setter Property="Text"
                                                Value="{Binding Fiyat, StringFormat='₺{0:N2}'}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="📈"
                                BackgroundColor="#6B7280"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="40" WidthRequest="44"
                                CommandParameter="{Binding .}"
                                Clicked="FiyatGecmisiClicked"/>
                        <Button Grid.Column="2"
        Text="✏️"
        IsVisible="{Binding Source={x:Reference ThisPage}, Path=YoneticiMi}"
        BackgroundColor="{StaticResource Primary}"
        TextColor="White"
        CornerRadius="8"
        HeightRequest="40" WidthRequest="44"
        CommandParameter="{Binding .}"
        Clicked="UrunDuzenleClicked"/>
                        <Button Grid.Column="3"
        Text="🗑️"
        IsVisible="{Binding Source={x:Reference ThisPage}, Path=YoneticiMi}"
        BackgroundColor="{StaticResource Danger}"
        TextColor="White"
        CornerRadius="8"
        HeightRequest="40" WidthRequest="44"
        CommandParameter="{Binding .}"
        Clicked="UrunSilClicked"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="⬅ Geri"
                Style="{StaticResource GrayBtn}"
                Clicked="GeriClicked"/>

    </VerticalStackLayout>
</ContentPage>