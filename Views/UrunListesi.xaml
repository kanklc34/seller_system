<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Saller_System.Models"
             x:Class="Saller_System.Views.UrunListesi"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B1220">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20,10,20,10" RowSpacing="15">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
            <Label Text="⬅" FontSize="24" TextColor="White" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="GeriClicked"/>
                </Label.GestureRecognizers>
            </Label>
            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5">
                <Label Text="Öz Biga" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Et" FontSize="20" FontAttributes="Bold" TextColor="#e31e24"/>
            </HorizontalStackLayout>
            <Label Grid.Column="2" x:Name="TarihLabel" Text="2026" TextColor="#94A3B8" FontSize="12" VerticalOptions="Center"/>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="#1E293B" Stroke="Transparent" StrokeShape="RoundRectangle 24" Padding="20">
            <VerticalStackLayout Spacing="12">

                <Border Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" Padding="12,0" HeightRequest="50">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="🏷️" VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Entry Grid.Column="1" x:Name="AdEntry" Placeholder="Ürün Adı" PlaceholderColor="#475569" TextColor="White" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Border Grid.Column="0" Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" Padding="12,0" HeightRequest="50">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Text="🔢" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Entry Grid.Column="1" x:Name="BarkodEntry" Placeholder="Barkod" PlaceholderColor="#475569" TextColor="White" Keyboard="Numeric"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" Padding="12,0" HeightRequest="50">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Text="📂" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Entry Grid.Column="1" x:Name="KategoriEntry" Placeholder="Kategori" PlaceholderColor="#475569" TextColor="White"/>
                        </Grid>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*, Auto" Padding="5,0">
                    <Label Text="⚖️ Gramajlı Ürün" TextColor="#CBD5E1" VerticalOptions="Center" FontSize="14"/>
                    <Switch Grid.Column="1" x:Name="GramajliSwitch" Toggled="GramajliToggled" OnColor="#e31e24"/>
                </Grid>

                <Grid x:Name="NormalFiyatPanel" ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Border Grid.Column="0" Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" Padding="12,0" HeightRequest="50">
                        <Entry x:Name="FiyatEntry" Placeholder="Satış ₺" PlaceholderColor="#475569" TextColor="White" Keyboard="Numeric"/>
                    </Border>
                    <Border Grid.Column="1" Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#0F172A" Padding="12,0" HeightRequest="50">
                        <Entry x:Name="AlisFiyatiEntry" Placeholder="Alış ₺" PlaceholderColor="#475569" TextColor="White" Keyboard="Numeric"/>
                    </Border>
                </Grid>

                <Button Text="Kaydet" BackgroundColor="#16A34A" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" Clicked="KaydetClicked"/>

            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Border Stroke="#374151" StrokeShape="RoundRectangle 12" BackgroundColor="#1E293B" Padding="10,0" HeightRequest="45">
                <SearchBar x:Name="UrunAraBar" Placeholder="Ürün ara..." TextChanged="UrunAraTextChanged" BackgroundColor="Transparent" TextColor="White" CancelButtonColor="Red"/>
            </Border>

            <CollectionView x:Name="UrunlerListesi" VerticalOptions="FillAndExpand">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Urun">
                        <Border BackgroundColor="#1E293B" Stroke="Transparent" StrokeShape="RoundRectangle 16" Padding="15" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                    <Label Text="{Binding Ad}" TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                    <Label TextColor="#16A34A" FontSize="13">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding GramajliMi}" Value="True">
                                                <Setter Property="Text" Value="{Binding KgFiyati, StringFormat='₺{0:N2} /Kg'}"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding GramajliMi}" Value="False">
                                                <Setter Property="Text" Value="{Binding Fiyat, StringFormat='₺{0:N2} /Adet'}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>

                                <Button Grid.Column="1" Text="📈" BackgroundColor="#7C3AED" WidthRequest="40" HeightRequest="40" CornerRadius="8" Padding="0" Clicked="FiyatGecmisiClicked" CommandParameter="{Binding .}"/>
                                <Button Grid.Column="2" Text="✏️" BackgroundColor="#16A34A" WidthRequest="40" HeightRequest="40" CornerRadius="8" Padding="0" Clicked="UrunDuzenleClicked" CommandParameter="{Binding .}"/>
                                <Button Grid.Column="3" Text="🗑️" BackgroundColor="#e31e24" WidthRequest="40" HeightRequest="40" CornerRadius="8" Padding="0" Clicked="UrunSilClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentPage>